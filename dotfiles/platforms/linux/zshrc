# Start of .zshrc file

# Load PATH
export PATH="/usr/local/bin:/usr/local/sbin:$HOME/.local/bin:$HOME/.config/composer/vendor/bin:$HOME/.local/share/JetBrains/Toolbox/scripts:$PATH"

# Verify Internet Connection
export HAS_CONNECTION="false"
export HAS_GITHUB_CONNECTION="false"
if nc -zw1 google.com 443 &>/dev/null 2>&1; then
    export HAS_CONNECTION="true"
    if nc -zw1 api.github.com 443 &>/dev/null 2>&1; then
        export HAS_GITHUB_CONNECTION="true"
    fi
fi

# Dotfile integrity state
export DOTFILE_COMPROMISED="false"
_DOTFILES_STATE_DIR="$HOME/.config/dotfiles"

_dotfiles_get_state() { local f="$_DOTFILES_STATE_DIR/$1"; [[ -f "$f" ]] && cat "$f" || echo ""; }
_dotfiles_set_state() { mkdir -p "$_DOTFILES_STATE_DIR"; echo "$2" > "$_DOTFILES_STATE_DIR/$1"; }
_dotfiles_clear_state() { rm -f "$_DOTFILES_STATE_DIR/$1"; }

_notify_linux() {
    local title="$1" message="$2"
    if command -v notify-send &>/dev/null; then
        notify-send "$title" "$message"
    fi
}

_apply_zshrc_update_linux() {
    local repo_path="dotfiles/platforms/linux/zshrc"
    local url="https://raw.githubusercontent.com/Im-Fran/Im-Fran/main/${repo_path}"
    local content
    content=$(curl -fsSL "$url")
    if [[ -n "$content" ]]; then
        echo "$content" > "$HOME/.zshrc"
        local new_hash
        new_hash=$(sha512sum "$HOME/.zshrc" | awk '{print $1}')
        _dotfiles_set_state "zshrc_hash" "$new_hash"
        _dotfiles_clear_state "zshrc_pending_update"
        _dotfiles_clear_state "zshrc_update_next"
        _notify_linux "Dotfiles" ".zshrc actualizado correctamente."
        echo "✅ .zshrc actualizado correctamente."
    fi
}

# Check for pending notifications from previous background integrity check
_check_pending_dotfile_notifications() {
    [[ -o interactive ]] || return 0

    # Tampering check
    if [[ -f "$_DOTFILES_STATE_DIR/zshrc_compromised" ]]; then
        export DOTFILE_COMPROMISED="true"
        echo ""
        echo "⚠️  ALERTA: ~/.zshrc fue modificado sin pasar por el repositorio oficial."
        echo "   Funciones que dependen de GitHub están bloqueadas."
        echo "   Para restaurar ejecuta: restore_dotfile zshrc"
        echo ""
        return 0
    fi

    # Update notification
    [[ -f "$_DOTFILES_STATE_DIR/zshrc_pending_update" ]] || return 0

    # Check silence
    local silence_until
    silence_until=$(_dotfiles_get_state "zshrc_silence_until")
    if [[ -n "$silence_until" && $(date +%s) -lt $silence_until ]]; then
        return 0
    fi
    [[ -n "$silence_until" ]] && _dotfiles_clear_state "zshrc_silence_until"

    # Auto-apply if "next start" was chosen
    if [[ -f "$_DOTFILES_STATE_DIR/zshrc_update_next" ]]; then
        _dotfiles_clear_state "zshrc_update_next"
        _dotfiles_clear_state "zshrc_pending_update"
        _apply_zshrc_update_linux
        return 0
    fi

    echo ""
    echo "📦 Nueva versión de .zshrc disponible. ¿Qué deseas hacer?"
    echo "   [1] Actualizar ahora (por defecto)"
    echo "   [2] Al siguiente inicio"
    echo "   [3] Omitir por ahora"
    echo ""
    local choice
    read -t 15 "choice?Elige una opción [1]: " || choice="1"
    choice="${choice:-1}"

    case "$choice" in
        2)
            _dotfiles_set_state "zshrc_update_next" "1"
            echo "Se actualizará en el próximo inicio de sesión."
            ;;
        3)
            echo ""
            echo "¿Por cuánto tiempo silenciar?"
            echo "   [1] 1h  [2] 3h  [3] 9h  [4] 12h"
            local s
            read -t 10 "s?Elige [1]: " || s="1"
            s="${s:-1}"
            local h
            case "$s" in 2) h=3 ;; 3) h=9 ;; 4) h=12 ;; *) h=1 ;; esac
            _dotfiles_set_state "zshrc_silence_until" "$(( $(date +%s) + h * 3600 ))"
            echo "Notificaciones silenciadas por ${h}h."
            ;;
        *)
            _dotfiles_clear_state "zshrc_pending_update"
            _apply_zshrc_update_linux
            ;;
    esac
}
_check_pending_dotfile_notifications

