## run-script ##
runscript() {
    if [[ "$DOTFILE_COMPROMISED" == "true" ]]; then
        echo "🚫 BLOQUEADO: ~/.zshrc fue modificado sin autorización."
        echo "   Ejecuta: restore_dotfile zshrc"
        return 1
    fi

    if [[ $# -lt 1 ]]; then
        echo "Usage: runscript <scriptname> [args...]"
        return 1
    fi

    if [[ -z "$GITHUB_TOKEN" ]]; then
        echo "GITHUB_TOKEN is not set. Make sure to create a token and set it in your .env!"
        return 1
    fi

    local script_name="$1"
    local cache_dir="$HOME/.cache/runscript"
    local local_script="$cache_dir/$script_name"
    local headers=(--header "Authorization: Bearer $GITHUB_TOKEN" --header "X-GitHub-Api-Version: 2022-11-28" --header "Cache-Control: no-cache")

    mkdir -p "$cache_dir"

    if [[ "$HAS_GITHUB_CONNECTION" == "false" ]]; then
        if [[ -f "$local_script" ]]; then
            echo "No hay conexión a GitHub. Usando copia local..."
            chmod +x "$local_script"
            shift
            zsh "$local_script" "$@"
            return $?
        else
            echo "No hay conexión a GitHub y no existe copia local del script."
            return 1
        fi
    fi

    # Try platform-specific first, fallback to shared
    local platform_url="https://api.github.com/repos/Im-Fran/Im-Fran/contents/dotfiles/platforms/macos/scripts/${script_name}"
    local shared_url="https://api.github.com/repos/Im-Fran/Im-Fran/contents/dotfiles/shared/scripts/${script_name}"

    local remote_script_content
    remote_script_content=$(curl -fsSL "$platform_url" "${headers[@]}" | jq -r 'if .content then .content else empty end' 2>/dev/null | base64 --decode 2>/dev/null)
    if [[ -z "$remote_script_content" ]]; then
        remote_script_content=$(curl -fsSL "$shared_url" "${headers[@]}" | jq -r 'if .content then .content else empty end' 2>/dev/null | base64 --decode 2>/dev/null)
    fi

    if [[ -z "$remote_script_content" ]]; then
        echo "Error: Script '$script_name' no encontrado en plataforma ni en compartidos."
        return 1
    fi

    local remote_hash
    remote_hash=$(echo "$remote_script_content" | shasum -a 512 | awk '{print $1}')

    if [[ -f "$local_script" ]]; then
        local local_hash
        local_hash=$(shasum -a 512 "$local_script" | awk '{print $1}')
        if [[ "$remote_hash" != "$local_hash" ]]; then
            echo "Actualizando script: $script_name"
            echo "$remote_script_content" > "$local_script" || { echo "Error: No se pudo guardar el script."; return 1; }
        fi
    else
        echo "Descargando script: $script_name"
        echo "$remote_script_content" > "$local_script" || { echo "Error: No se pudo guardar el script."; return 1; }
    fi

    chmod +x "$local_script"
    shift
    zsh "$local_script" "$@"
}

