# Functions
restore_dotfile() {
    local name="$1"
    if [[ -z "$name" ]]; then
        echo "Usage: restore_dotfile <name>"
        echo "Disponibles: zshrc"
        return 1
    fi

    local repo_path local_path
    case "$name" in
        zshrc)
            repo_path="dotfiles/platforms/macos/zshrc"
            local_path="$HOME/.zshrc"
            ;;
        *)
            echo "Dotfile desconocido: $name"
            return 1
            ;;
    esac

    if [[ "$HAS_GITHUB_CONNECTION" == "false" ]]; then
        echo "Error: No hay conexión a GitHub para restaurar."
        return 1
    fi

    if [[ -z "$GITHUB_TOKEN" ]]; then
        echo "Error: GITHUB_TOKEN no está configurado."
        return 1
    fi

    echo "Descargando $name desde el repositorio oficial..."
    local url="https://api.github.com/repos/Im-Fran/Im-Fran/contents/${repo_path}"
    local content
    content=$(curl -fsSL "$url" \
        --header "Authorization: Bearer $GITHUB_TOKEN" \
        --header "X-GitHub-Api-Version: 2022-11-28" \
        --header "Cache-Control: no-cache" | jq -r .content | base64 --decode)

    if [[ -z "$content" ]]; then
        echo "Error: No se pudo descargar el archivo."
        return 1
    fi

    # Verify hash against .hashes.json
    local hashes_json
    hashes_json=$(curl -fsSL "https://api.github.com/repos/Im-Fran/Im-Fran/contents/.hashes.json" \
        --header "Authorization: Bearer $GITHUB_TOKEN" \
        --header "X-GitHub-Api-Version: 2022-11-28" \
        --header "Cache-Control: no-cache" | jq -r .content | base64 --decode)

    if [[ -n "$hashes_json" ]]; then
        local expected_hash actual_hash
        expected_hash=$(echo "$hashes_json" | jq -r ".files[\"${repo_path}\"]" 2>/dev/null)
        actual_hash=$(echo "$content" | shasum -a 512 | awk '{print $1}')

        if [[ -n "$expected_hash" && "$expected_hash" != "null" && "$expected_hash" != "$actual_hash" ]]; then
            echo "⚠️  El hash del archivo descargado no coincide con .hashes.json."
            echo "   Abortando la restauración por integridad."
            return 1
        fi
    fi

    echo "$content" > "$local_path"
    local final_hash
    final_hash=$(shasum -a 512 "$local_path" | awk '{print $1}')
    _dotfiles_set_state "${name}_hash" "$final_hash"
    _dotfiles_clear_state "${name}_compromised"
    _dotfiles_clear_state "${name}_pending_update"
    _dotfiles_clear_state "${name}_update_next"
    export DOTFILE_COMPROMISED="false"
    echo "✅ $name restaurado correctamente."
    osascript -e "display notification \"$name restaurado desde el repositorio oficial.\" with title \"Dotfiles\""
}

# Background integrity check
_check_dotfile_updates() {
    [[ "$HAS_GITHUB_CONNECTION" == "false" ]] && return 1
    [[ -z "$GITHUB_TOKEN" ]] && return 1

    local repo_path="dotfiles/platforms/macos/zshrc"
    mkdir -p "$_DOTFILES_STATE_DIR"

    # Respect silence setting
    local silence_until
    silence_until=$(_dotfiles_get_state "zshrc_silence_until")
    if [[ -n "$silence_until" && $(date +%s) -lt $silence_until ]]; then
        return 0
    fi

    local local_hash
    local_hash=$(shasum -a 512 "$HOME/.zshrc" | awk '{print $1}')

    local last_applied_hash
    last_applied_hash=$(_dotfiles_get_state "zshrc_hash")
    if [[ -z "$last_applied_hash" ]]; then
        _dotfiles_set_state "zshrc_hash" "$local_hash"
        last_applied_hash="$local_hash"
    fi

    local hashes_json
    hashes_json=$(curl -fsSL "https://api.github.com/repos/Im-Fran/Im-Fran/contents/.hashes.json" \
        --header "Authorization: Bearer $GITHUB_TOKEN" \
        --header "X-GitHub-Api-Version: 2022-11-28" \
        --header "Cache-Control: no-cache" | jq -r .content | base64 --decode)

    [[ -z "$hashes_json" ]] && return 1

    local remote_expected_hash
    remote_expected_hash=$(echo "$hashes_json" | jq -r ".files[\"${repo_path}\"]" 2>/dev/null)
    [[ -z "$remote_expected_hash" || "$remote_expected_hash" == "null" ]] && return 1

    # Caso A: todo sincronizado
    if [[ "$local_hash" == "$remote_expected_hash" ]]; then
        _dotfiles_set_state "zshrc_hash" "$local_hash"
        return 0
    fi

    # Caso D: el usuario sincronizó manualmente
    if [[ "$local_hash" != "$last_applied_hash" && "$local_hash" == "$remote_expected_hash" ]]; then
        _dotfiles_set_state "zshrc_hash" "$local_hash"
        return 0
    fi

    # Caso C: tampering — local cambió pero no coincide con remoto
    if [[ "$local_hash" != "$last_applied_hash" && "$local_hash" != "$remote_expected_hash" ]]; then
        _dotfiles_set_state "zshrc_compromised" "1"
        osascript -e 'display notification "⚠️ ~/.zshrc fue modificado sin autorización. Ejecuta: restore_dotfile zshrc" with title "Dotfiles - Alerta de Seguridad" sound name "Basso"'
        return 0
    fi

    # Caso B: actualización disponible
    _dotfiles_set_state "zshrc_pending_update" "1"
}
_check_dotfile_updates &!

